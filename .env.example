# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Google Gemini AI
NEXT_PUBLIC_GEMINI_API_KEY=

# Neon PostgreSQL Database (server-only, no NEXT_PUBLIC_ prefix)
DATABASE_URL=

# App URL
NEXT_PUBLIC_HOST_NAME=http://localhost:3000

# ===== AI PROVIDER =====
# Options: google | openai | anthropic
AI_PROVIDER=google

# Optional: YouTube API Key (for video search)
# NEXT_PUBLIC_YOUTUBE_API_KEY=

# ===== STORAGE =====
# Options: local | cloudinary
STORAGE_PROVIDER=local

# Cloudinary (if using cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Local storage directory (if using local)
# LOCAL_STORAGE_DIR=./public/uploads

# ===== BACKGROUND JOBS (Inngest) =====
# Get keys at https://inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ===== CACHING (Upstash Redis) =====
# Get keys at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== MEDIA GENERATION =====
# Fal.ai (course banner generation)
# Get key at https://fal.ai
FAL_KEY=

# AssemblyAI (audio transcription)
# Get key at https://assemblyai.com
ASSEMBLYAI_API_KEY=

# ElevenLabs (text-to-speech)
# Get key at https://elevenlabs.io
ELEVENLABS_API_KEY=

# ===== SEMANTIC SEARCH (Upstash Vector) =====
# Get keys at https://upstash.com (enable Vector in dashboard)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ===== CONTENT VERIFICATION =====
# Tavily (web search verification)
# Get key at https://tavily.com
TAVILY_API_KEY=
